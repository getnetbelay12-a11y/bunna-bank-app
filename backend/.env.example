NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DEMO_MODE=true
APP_NAME=Bunna Bank API
APP_LOG_LEVEL=debug
CLIENT_APP_ORIGIN=*

MONGODB_URI=mongodb://localhost:27017/bunna_bank_app

JWT_SECRET=CHANGE_THIS_SECRET_TO_AT_LEAST_16_CHARS
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

OTP_ENABLED=true
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_SIGNING_SECRET=CHANGE_THIS_OTP_SECRET_TO_AT_LEAST_16_CHARS
REPORTING_SNAPSHOT_LOOKBACK_DAYS=14
REPORTING_SNAPSHOT_LOCK_MINUTES=10
ONBOARDING_REVIEW_POLICY_VERSION=v1
ONBOARDING_BLOCKING_MISMATCH_FIELDS=fullName,firstName,lastName,dateOfBirth,phoneNumber,faydaFin
ONBOARDING_BLOCKING_MISMATCH_APPROVAL_ROLES=head_office_manager,admin
ONBOARDING_BLOCKING_MISMATCH_APPROVAL_REASON_CODES=official_source_verified,manual_document_review,customer_profile_corrected
ONBOARDING_REQUIRE_APPROVAL_JUSTIFICATION=true

SMS_ENABLED=true
SMS_PROVIDER=log
SMS_SENDER_ID=BUNNA_BANK
SMS_GENERIC_ENDPOINT=
SMS_GENERIC_API_KEY=

EMAIL_ENABLED=true
EMAIL_PROVIDER=log
EMAIL_SENDER=notifications@bunna-bank.local
EMAIL_GENERIC_ENDPOINT=
EMAIL_GENERIC_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=notifications@bunna-bank.local
DEMO_NOTIFICATION_EMAIL=

PUSH_ENABLED=true
PUSH_PROVIDER=log
PUSH_GENERIC_ENDPOINT=
PUSH_GENERIC_API_KEY=
PUSH_IOS_SIMULATOR_DEVICE=booted
PUSH_IOS_SIMULATOR_BUNDLE_ID=com.getnetbelay.bunnaBankMobile
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.getnetbelay.bunnaBankMobile
APNS_PRIVATE_KEY=
APNS_USE_SANDBOX=true

STORAGE_PROVIDER=local
FILE_UPLOAD_PATH=uploads/
AWS_REGION=
AWS_S3_BUCKET=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
