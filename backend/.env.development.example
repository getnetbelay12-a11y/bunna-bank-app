NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_NAME=CBE Bank API
APP_LOG_LEVEL=debug
CLIENT_APP_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://localhost:27017/cbe_bank_app

JWT_SECRET=CHANGE_THIS_SECRET
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

OTP_ENABLED=true
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_SIGNING_SECRET=CHANGE_THIS_OTP_SECRET

SMS_ENABLED=true
SMS_PROVIDER=log
SMS_SENDER_ID=CBE_BANK
SMS_GENERIC_ENDPOINT=
SMS_GENERIC_API_KEY=

EMAIL_ENABLED=true
EMAIL_PROVIDER=log
EMAIL_SENDER=notifications@cbe-bank.local
EMAIL_GENERIC_ENDPOINT=
EMAIL_GENERIC_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

PUSH_ENABLED=true
PUSH_PROVIDER=log
PUSH_GENERIC_ENDPOINT=
PUSH_GENERIC_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

STORAGE_PROVIDER=local
FILE_UPLOAD_PATH=uploads/
AWS_REGION=
AWS_S3_BUCKET=
